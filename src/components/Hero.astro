---
---

<section class="pt-40 pb-24 px-6">
  <div class="max-w-5xl mx-auto">
    <div class="fade-up">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 mb-8 rounded-full border border-[color:var(--color-border)] bg-[color:var(--color-surface)] text-xs text-[color:var(--color-text-muted)] font-mono">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-[color:var(--color-accent)] opacity-75"></span>
          <span class="relative inline-flex h-2 w-2 rounded-full bg-[color:var(--color-accent)]"></span>
        </span>
        <span>Available for freelance — accepting 1–2 clients this quarter</span>
      </div>

      <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold leading-[1.05] tracking-tight mb-6">
        I build React Native apps<br />
        that talk to <span class="text-[color:var(--color-accent)]">hardware</span>.
      </h1>

      <p class="text-lg sm:text-xl text-[color:var(--color-text-muted)] max-w-2xl leading-relaxed mb-10">
        Freelance mobile developer with 4+ years shipping production iOS and Android apps.
        I specialize in native modules and the messy bits — USB serial, Bluetooth,
        hardware accessories, custom Kotlin and Swift bridges.
      </p>

      <div class="flex flex-wrap items-center gap-4">
        <a
          href="#work"
          class="inline-flex items-center gap-2 px-5 py-2.5 bg-[color:var(--color-accent)] text-[color:var(--color-bg)] rounded-md font-medium hover:opacity-90 transition-opacity"
        >
          See my work
          <span aria-hidden="true">→</span>
        </a>
        <a
          href="#contact"
          class="inline-flex items-center gap-2 px-5 py-2.5 border border-[color:var(--color-border)] rounded-md text-sm font-medium hover:border-[color:var(--color-text-muted)] transition-colors"
        >
          Get in touch
        </a>
      </div>
    </div>
  </div>
</section>
